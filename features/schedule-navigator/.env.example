# =============================================================================
# Schedule Navigator (features/schedule-navigator)
# Standalone Express app on PORT (default 3002).
# Reads its own .env via `require('dotenv').config()` in index.js / scraper.js.
# =============================================================================

# Groq — used by index.js to generate 1-2 sentence AI explanations for the
# top 5 scored sessions. Get a free key at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# Supabase — scraper.js uses the service_role key to read the `sessions` table.
# SUPABASE_URL is the same as backend/.env; the service_role key lives in
# Supabase Dashboard → Project Settings → API → "service_role" (secret).
# IMPORTANT: service_role bypasses RLS — never expose it to the browser.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOi_your_service_role_key_here

# Optional. Defaults to 3002 if unset (3000 = Next.js, 3001 = backend).
# PORT=3002
