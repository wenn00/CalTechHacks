# =============================================================================
# Existing backend configuration
# =============================================================================

# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Database — Prisma + Supabase Postgres
DATABASE_URL=postgresql://...

# Supabase
SUPABASE_URL=https://....supabase.co

# =============================================================================
# ARDD Community Slack Bot (/ardd ...)
# =============================================================================

# Slack — Socket Mode needs bot + app tokens only.
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_DIGEST_CHANNEL_ID=C...

# Comma-separated Slack user IDs allowed to run /ardd announce.
ADMIN_SLACK_USER_IDS=U123,U456

# Conference dates — single source of truth for /ardd schedule, daily digest,
# and the conferenceDay backfill. Both keys are YYYY-MM-DD strings in
# CONFERENCE_TIMEZONE local time.
CONFERENCE_TIMEZONE=America/Los_Angeles
CONFERENCE_START_DATE_KEY=2026-09-01

# Feature gates — keep OFF by default so tests / preview deploys / scripts
# that import index.ts do not accidentally start the bot or cron.
ENABLE_SLACK_BOT=false
ENABLE_DAILY_DIGEST_CRON=false

# Demo / determinism — optional ISO timestamp override for "now". When set,
# getEffectiveNow() returns this instead of the system clock, so /ardd now,
# /ardd schedule today, and the daily digest produce conference-day-relative
# output on any wall-clock day. Leave unset in normal runtime.
# DEMO_NOW_ISO=2026-09-01T10:15:00-07:00

# Optional. Only needed if switching from Socket Mode to HTTP receiver later.
# SLACK_SIGNING_SECRET=
